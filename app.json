{
  "expo": {
    "name": "Vmail",
    "slug": "veille-email-mobile",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "veilleemailmobile",
    "userInterfaceStyle": "automatic",
    "ios": {
      "icon": "./assets/images/icon.png",
      "bundleIdentifier": "fr.veilleemail.app",
      "supportsTablet": true,
      "infoPlist": {
        "NSPhotoLibraryUsageDescription": "Autorisez l'accès à vos photos pour les joindre à vos réponses.",
        "NSCameraUsageDescription": "Autorisez l'accès à l'appareil photo pour joindre une photo à vos réponses."
      }
    },
    "android": {
      "package": "fr.veilleemail.app",
      "adaptiveIcon": {
        "backgroundColor": "#211e19",
        "foregroundImage": "./assets/images/android-icon-foreground.png",
        "monochromeImage": "./assets/images/android-icon-monochrome.png"
      },
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "output": "single",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-image-picker",
        {
          "photosPermission": "Autorisez l'accès à vos photos pour les joindre à vos réponses.",
          "cameraPermission": "Autorisez l'accès à l'appareil photo pour joindre une photo à vos réponses."
        }
      ],
      [
        "expo-localization",
        {
          "supportsRTL": true
        }
      ],
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#211e19",
          "android": {
            "image": "./assets/images/splash-icon.png",
            "imageWidth": 76
          }
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    }
  }
}

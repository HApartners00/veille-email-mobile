# Copier ce fichier en `.env` et renseigner les valeurs (Supabase → Project Settings → API).
# Variables publiques (clé "publishable"/anon, embarquées côté client — jamais la service_role).
EXPO_PUBLIC_SUPABASE_URL=https://VOTRE-PROJET.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=sb_publishable_xxx
EXPO_PUBLIC_API_BASE=https://veille-email-app.vercel.app
